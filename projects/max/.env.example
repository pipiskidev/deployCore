# Public hostname for the max app. Replace placeholder in nginx.conf with the
# same value via the README one-liner before bringing up the stack.
MAX_DOMAIN=max.example.com

# MongoDB credentials. Generate a fresh password — the value used in the old
# repo (deployCore/{backend,database}/docker-compose.yml) is compromised.
#   openssl rand -base64 32
MONGO_USER=root
MONGO_PASSWORD=

# Host paths for the backend jar and the frontend sources.
# Override if your deploy layout differs.
BACKEND_JAR_DIR=/home/maxAgent/backend/target
FRONTEND_DIR=/home/maxAgent/frontend/sources
STATIC_DIR=/home/static

TZ=Europe/Moscow
