# Global infrastructure variables for deployCore.
# Copy to .env and fill in real values. Do NOT commit .env.

# Email used by Let's Encrypt for expiry notices and account recovery.
LETSENCRYPT_EMAIL=admin@example.com

# Default timezone for containers that respect TZ.
TZ=Europe/Moscow

# Set to 1 to use Let's Encrypt staging (rate-limit-free, but certs are not trusted).
# Useful for testing add-project.sh end-to-end without burning real ACME quota.
ACME_STAGING=0
