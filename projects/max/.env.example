# Public hostname for the max app. Replace placeholder in nginx.conf with the
# same value via the README one-liner before reloading nginx.
MAX_DOMAIN=max.example.com

# MongoDB credentials. GENERATE A FRESH PASSWORD:
#   openssl rand -base64 32
# (The literal that lived in the original deployCore is COMPROMISED — rotate
# in a running mongo with: db.changeUserPassword("root","<new>") )
MONGO_USER=root
MONGO_PASSWORD=

# Host paths for the backend jar and frontend sources. The compose mounts
# these into the containers; build artefacts must land here outside Docker.
BACKEND_JAR_DIR=/home/maxAgent/backend/target
FRONTEND_DIR=/home/maxAgent/frontend/sources
STATIC_DIR=/home/static

TZ=Europe/Moscow
