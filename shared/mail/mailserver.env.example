# Mail server configuration. Copy to mailserver.env and fill in.

# Public hostname for the mail server. Must have a valid Let's Encrypt cert
# issued via core/certbot (../../scripts/issue-cert.sh smtp.example.com).
MAIL_DOMAIN=example.com
MAIL_HOSTNAME=smtp
LETSENCRYPT_DOMAIN=smtp.example.com

ENABLE_SSL=1
SSL_TYPE=letsencrypt
LETSENCRYPT_EMAIL=admin@example.com

POSTMASTER_ADDRESS=admin@example.com

ENABLE_SPAMASSASSIN=1
ENABLE_CLAMAV=1
ENABLE_FAIL2BAN=1
ENABLE_POSTGREY=1
