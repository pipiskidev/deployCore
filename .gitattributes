# Force LF for files that are executed/parsed on Linux servers, regardless of
# the contributor's local core.autocrlf setting. CRLF in shell scripts breaks
# bash; CRLF in nginx.conf is tolerated but ugly.

*.sh        text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile  text eol=lf
.gitkeep    text eol=lf
.env.example text eol=lf

# Markdown / docs — leave to platform default.
*.md        text
