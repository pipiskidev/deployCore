# Public hostname for the example app. Replace placeholder in nginx.conf with the
# same value via the README one-liner before reloading nginx.
# Required only if you bring up `example-web` or `example-backend` (anything fronted
# by nginx). Skip / leave empty for a backend-only internal deployment.
EXAMPLE_DOMAIN=example.example.com

# MongoDB credentials. GENERATE A FRESH PASSWORD:
#   openssl rand -base64 32
# Required only if you bring up example-backend or example-mongo.
MONGO_USER=root
MONGO_PASSWORD=

# Host paths for the backend jar and frontend sources. The compose mounts
# these into the containers; build artefacts must land here outside Docker.
BACKEND_JAR_DIR=/home/exampleProject/backend/target
FRONTEND_DIR=/home/exampleProject/frontend/sources
STATIC_DIR=/home/static

TZ=Europe/Moscow
